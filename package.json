{
  "name": "whatsapp-api-gateway",
  "version": "1.0.0",
  "description": "API gateway for whatsapp-web.js secured with Keycloak, documented with tsoa/Swagger.",
  "main": "dist/server.js",
  "scripts": {
    "tsoa": "tsoa spec-and-routes",
    "spec": "tsoa spec",
    "routes": "tsoa routes",
    "build": "tsoa spec-and-routes && tsc",
    "start": "node dist/server.js",
    "predev": "tsoa spec-and-routes",
    "dev": "nodemon --watch src --ext ts --ignore src/generated --exec \"ts-node src/server.ts\"",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@tsoa/runtime": "^6.6.0",
    "dotenv": "^16.4.5",
    "elastic-apm-node": "^4.15.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "tsyringe": "^4.8.0",
    "whatsapp-web.js": "^1.26.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/swagger-ui-express": "^4.1.6",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
