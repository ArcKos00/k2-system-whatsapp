# ── HTTP server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Sub-path the service is served under behind an ingress (Kubernetes).
# Leave empty when served at the root. Example: /whatsapp-api
PATH_BASE=

# ── Keycloak (token validation) ────────────────────────────────
# Base URL WITHOUT trailing slash and WITHOUT /realms.
KEYCLOAK_AUTH_SERVER_URL=https://keycloak.example.com
KEYCLOAK_REALM=k2-system
# Expected token audience (client id). Leave empty to skip audience check.
# Requires an "Audience" mapper in Keycloak to populate `aud`.
KEYCLOAK_AUDIENCE=whatsapp-api

# ── WhatsApp (whatsapp-web.js) ─────────────────────────────────
# Logical session id (allows multiple numbers under one data path).
WHATSAPP_CLIENT_ID=default
# Persisted LocalAuth session directory — mount as a volume for persistence.
WHATSAPP_SESSION_PATH=/app/data/sessions
# Minimum delay (ms) between outbound messages to reduce ban risk.
WHATSAPP_MESSAGE_DELAY_MS=3000
# Where the login QR PNG is written (defaults to <session path>/qr.png).
# WHATSAPP_QR_PATH=/app/data/qr.png

# ── Puppeteer / Chromium ───────────────────────────────────────
# Browser resolution priority: PUPPETEER_EXECUTABLE_PATH > PUPPETEER_BROWSER_CHANNEL > bundled.
#
# In Docker: point at the system Chromium installed by the Dockerfile.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_DOWNLOAD=true
#
# For LOCAL dev (Windows/macOS) leave PUPPETEER_EXECUTABLE_PATH unset and instead
# launch an already-installed browser channel — no Chromium download needed:
# PUPPETEER_BROWSER_CHANNEL=chrome
